---
import { getCollection, render } from 'astro:content';
import ChapterLayout from '../../layouts/ChapterLayout.astro';

export async function getStaticPaths() {
  const chapters = await getCollection('chapters', ({ data }) => !data.draft);
  const sorted = chapters.sort((a, b) => a.data.chapterNumber - b.data.chapterNumber);

  return sorted.map((chapter, index) => ({
    params: { id: chapter.id },
    props: {
      chapter,
      prevChapter: index > 0 ? sorted[index - 1] : undefined,
      nextChapter: index < sorted.length - 1 ? sorted[index + 1] : undefined,
    },
  }));
}

const { chapter, prevChapter, nextChapter } = Astro.props;
const { Content } = await render(chapter);
---
<ChapterLayout chapter={chapter} prevChapter={prevChapter} nextChapter={nextChapter}>
  <Content />
</ChapterLayout>

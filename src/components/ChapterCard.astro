---
import type { CollectionEntry } from 'astro:content';

interface Props {
  chapter: CollectionEntry<'chapters'>;
}

const { chapter } = Astro.props;
const { chapterNumber, title, subtitle, pubDate, tags } = chapter.data;
const base = import.meta.env.BASE_URL;
const href = `${base}chapters/${chapter.id}`;
---
<article class="chapter-card">
  <a href={href} class="card-link">
    <span class="card-number">Chapter {chapterNumber}</span>
    <h2 class="card-title">{title}</h2>
    {subtitle && <p class="card-subtitle">{subtitle}</p>}
    <div class="card-meta">
      <time datetime={pubDate.toISOString()}>
        {pubDate.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      {tags.length > 0 && (
        <ul class="card-tags" role="list">
          {tags.map(tag => <li class="tag">{tag}</li>)}
        </ul>
      )}
    </div>
  </a>
</article>

<style>
  .chapter-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
  }
  .chapter-card:hover {
    box-shadow: 0 6px 24px rgba(0,0,0,0.08);
    border-color: var(--color-accent-light);
  }
  .card-link {
    display: block;
    padding: 1.5rem 2rem;
    text-decoration: none;
    color: inherit;
  }
  .card-number {
    display: block;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-chapter-num);
    margin-bottom: 0.5rem;
    font-family: var(--font-sans);
  }
  .card-title {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.35;
    margin-bottom: 0.4rem;
  }
  .card-subtitle {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    font-style: italic;
    margin-bottom: 1rem;
  }
  .card-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    font-size: 0.8rem;
    color: var(--color-text-subtle);
    font-family: var(--font-sans);
  }
  .card-tags { display: flex; gap: 0.4rem; list-style: none; padding: 0; }
  .tag {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    padding: 0.1rem 0.5rem;
    border-radius: 4px;
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }
</style>
